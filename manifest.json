{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "alu-automation-templates",
  "description": "Reusable Claude Code skill templates for Product Management, Scrum Master, and developer productivity workflows with Jira integration.",
  "version": "1.0.0",
  "author": "Dan Alu",
  "repository": "https://github.com/DTdalu/alu-automation-templates",
  "license": "MIT",
  "lastUpdated": "2026-01-15",
  "categories": [
    {
      "id": "project-management",
      "name": "Project Management",
      "description": "Skills for agile project management, Jira integration, and team coordination"
    }
  ],
  "skills": [
    {
      "id": "scrum-master",
      "name": "Scrum Master",
      "description": "Technical Scrum Master for story breakdown, test case definition, repo-to-story traceability, and Jira management.",
      "version": "1.0.0",
      "category": "project-management",
      "scope": "project",
      "path": "templates/project-management/scrum-master",
      "entryPoint": "SKILL.template.md",
      "placeholders": [
        {
          "key": "CLOUD_ID",
          "description": "Atlassian Cloud ID (UUID format)",
          "required": true,
          "example": "550c6b47-250d-452d-afe8-8e200810656f"
        },
        {
          "key": "PROJECT_KEY",
          "description": "Jira project key",
          "required": true,
          "example": "PE"
        },
        {
          "key": "EPIC_KEY",
          "description": "Default epic issue key",
          "required": true,
          "example": "PE-38"
        }
      ],
      "references": [
        "references/jira-patterns.template.md"
      ],
      "dependencies": [],
      "keywords": ["scrum", "agile", "jira", "stories", "sprint", "backlog"]
    },
    {
      "id": "product-manager",
      "name": "Product Manager",
      "description": "Product management specialist for PRD creation, stakeholder communication, epic definition, and Jira card management.",
      "version": "1.0.0",
      "category": "project-management",
      "scope": "project",
      "path": "templates/project-management/product-manager",
      "entryPoint": "SKILL.template.md",
      "placeholders": [
        {
          "key": "CLOUD_ID",
          "description": "Atlassian Cloud ID (UUID format)",
          "required": true,
          "example": "550c6b47-250d-452d-afe8-8e200810656f"
        },
        {
          "key": "PROJECT_KEY",
          "description": "Jira project key",
          "required": true,
          "example": "PE"
        },
        {
          "key": "EPIC_KEY",
          "description": "Default epic issue key",
          "required": true,
          "example": "PE-38"
        }
      ],
      "references": [
        "references/jira-patterns.template.md",
        "references/prd-template.md",
        "references/status-report-template.md"
      ],
      "dependencies": [],
      "keywords": ["product", "prd", "requirements", "jira", "epic", "status"]
    },
    {
      "id": "session-log",
      "name": "Session Log",
      "description": "Generate structured session logs capturing git activity, accomplishments, and context for Jira updates and stand-ups.",
      "version": "1.0.0",
      "category": "project-management",
      "scope": "user",
      "path": "templates/project-management/session-log",
      "entryPoint": "SKILL.template.md",
      "placeholders": [
        {
          "key": "PROJECT_NAME",
          "description": "Name of the project for log headers",
          "required": false,
          "default": "Project",
          "example": "Invoice Automation"
        },
        {
          "key": "EPIC_KEY",
          "description": "Default epic for Jira context",
          "required": false,
          "default": "",
          "example": "PE-38"
        },
        {
          "key": "PROJECT_KEY",
          "description": "Jira project key for story references",
          "required": false,
          "default": "",
          "example": "PE"
        },
        {
          "key": "LOGS_PATH",
          "description": "Path to store session logs",
          "required": false,
          "default": "docs/logs/",
          "example": "docs/logs/"
        }
      ],
      "references": [
        "templates/session-log-template.md"
      ],
      "dependencies": [],
      "keywords": ["session", "log", "standup", "git", "commits", "pr"]
    }
  ],
  "installation": {
    "targetPaths": {
      "project": ".claude/skills/",
      "user": "~/.claude/skills/"
    },
    "fileRenaming": {
      ".template.md": ".md"
    }
  }
}
